{
  "name": "lumstate",
  "version": "0.0.2",
  "description": "Framework-agnostic in-memory state management. No localStorage, no cookies. State lives in memory, syncs across tabs, and self-destructs on logout or tab close.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./react.js"
    },
    "./vue": {
      "types": "./vue.d.ts",
      "import": "./vue.js"
    },
    "./svelte": {
      "types": "./svelte.d.ts",
      "import": "./svelte.js"
    },
    "./vanilla": {
      "types": "./vanilla.d.ts",
      "import": "./vanilla.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "core.js",
    "react.js",
    "react.d.ts",
    "vue.js",
    "vue.d.ts",
    "svelte.js",
    "svelte.d.ts",
    "vanilla.js",
    "vanilla.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node core.test.mjs",
    "build": "echo 'Pure ESM — no build step needed'",
    "prepublishOnly": "npm test"
  },
  "typesVersions": {
    "*": {
      "react": ["react.d.ts"],
      "vue": ["vue.d.ts"],
      "svelte": ["svelte.d.ts"],
      "vanilla": ["vanilla.d.ts"]
    }
  },
  "keywords": [
    "state-management",
    "store",
    "memory",
    "no-storage",
    "session",
    "react",
    "vue",
    "svelte",
    "vanilla",
    "framework-agnostic",
    "broadcast-channel",
    "pinia",
    "redux"
  ],
  "author": "Jonas Kabalo <kabalojonas44@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JonasKabalo/lumstate"
  },
  "homepage": "https://github.com/JonasKabalo/lumstate#readme",
  "bugs": {
    "url": "https://github.com/JonasKabalo/lumstate/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "vue": ">=3.0.0",
    "svelte": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true },
    "svelte": { "optional": true }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false
}
